# Exclude source platform dirs (not needed for web deployment)
android/
ios/
macos/
windows/
linux/
test/
web/

# Exclude Dart tooling & IDE files
.dart_tool/
.pub-cache/
coverage/
.idea/
.vscode/

# Exclude API key
lib/services/api_key.dart

# Exclude build artifacts except the web output
/build/
!/build/web/
